{
  // Configurações gerais do ambiente
  "workbench.iconTheme": "vscode-icons",
  "workbench.startupEditor": "none",
  "explorer.compactFolders": false,

  //Fontes
  "editor.fontSize": 15,
  "editor.fontLigatures": true,
  "terminal.integrated.fontFamily": "Fira Code",
  "editor.fontFamily": "Fira Code",

  // Configurações do Flake8
  "flake8.args": [
    "--max-line-length=88"
  ],
  "flake8.ignorePatterns": [
    "**/site-packages/**/*.py",
    ".vscode/*.py"
  ],
  "flake8.importStrategy": "useBundled",
  "flake8.path": [
    "venv/bin/flake8"
  ],
  "flake8.showNotifications": "always",

  // Configurações do Autopep8
  "autopep8.args": [
    "--max-line-length=88",
    "--ignore=E203, E266, E501, W503, F403, F401"
  ],


  // Configurações do Black
  "black-formatter.args": [
    "--line-length=88",
    "--skip-string-normalization",
    "--skip-magic-trailing-comma",
    "--skip-magic-reorder",
    "--skip-string-normalization",
    "--skip-numer"
  ],
  "black-formatter.showNotifications": "always",

  // Configurações para linguagens específicas (Python, HTML, Django, etc.)
  "python.autoComplete.extraPaths": [
    "venv/lib/python3.11"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": [],
  "python.defaultInterpreterPath": "venv/bin/python",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "[html]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.quickSuggestions": {
      "other": true,
      "comments": true,
      "strings": true
    }
  },
  "[django-html]": {
    "editor.formatOnSave": false,
    "editor.defaultFormatter": "vscode.html-language-features",
    "editor.quickSuggestions": {
      "other": true,
      "comments": true,
      "strings": true
    }
  },
  // Associações de arquivos para diferentes linguagens
  "files.associations": {
    "*.js": "javascript",
    "*.jsx": "javascriptreact",
    "*.xml": "html",
    "*.svg": "html",
    "*.html": "html",
    "django-html": "html",
    "**/*.html": "html",
    "**/templates/**/*.html": "django-html",
    "**/base_templates/**/*.html": "django-html",
    "**/requirements{/**,*}.{txt,in}": "pip-requirements"
  },
  "emmet.includeLanguages": {
    "django-html": "html",
    "javascript": "javascriptreact",
    "typescript": "typescriptreact"
  },

  // Configurações do code-runner
  "code-runner.runInTerminal": true,
  "code-runner.clearPreviousOutput": true,
  "code-runner.executorMap": {
    "javascript": "node",
    "c": "cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
    "python": "clear ; python -u",
    "typescript": "ts-node"
  },
  "code-runner.ignoreSelection": true,

  // Outras configurações gerais
  "git.autofetch": true,
  "git.confirmSync": false,
  "liveServer.settings.donotShowInfoMsg": true,
  "workbench.colorTheme": "Monokai",
  "gitlens.gitCommands.skipConfirmations": [
    "fetch:command",
    "switch:command"
  ],
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit"
  },
  "files.autoSave": "onFocusChange",
  "git.ignoreMissingGitWarning": true,
  "githubPullRequests.pullBranch": "never",
  "editor.unicodeHighlight.allowedCharacters": {
    "ã": true
  },
  "editor.unicodeHighlight.includeStrings": false,
  "editor.unicodeHighlight.includeComments": false,
  "github.copilot.advanced": {
    "enabled": true
  },
  "github.copilot.editor.enableAutoCompletions": true,
  "window.zoomLevel": 0.1,
  "remote.autoForwardPortsSource": "hybrid",
  "editor.cursorStyle": "line-thin",
  "editor.cursorSmoothCaretAnimation": "explicit",
  "editor.wordWrap": "wordWrapColumn",
  "files.trimTrailingWhitespace": true,
  "pythonIndent.trimLinesWithOnlyWhitespace": true,
  "editor.minimap.autohide": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.pytestParameters": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.addImport.exactMatchOnly": true,
  "python.analysis.indexing": false,
  "pythonIndent.useTabOnHangingIndent": true,
  "editor.formatOnPaste": true,
  "python.experiments.enabled": false,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.enablePytestExtra": false,
  "intellicodeApiExamples.python.enabled": false,
  "python.analysis.extraPaths": [
    "venv/lib/python3.11"
  ],
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "githubPullRequests.createOnPublishBranch": "never",

}
